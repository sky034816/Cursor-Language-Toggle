{
  "name": "cursor-zh-toggle",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "icon": "media/logo.png",
  "version": "1.0.2",
  "publisher": "eric-lin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sky034816/Cursor-toggle.git"
  },
  "homepage": "https://github.com/sky034816/Cursor-toggle#readme",
  "bugs": {
    "url": "https://github.com/sky034816/Cursor-toggle/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./main.js",
  "files": [
    "main.js",
    "package.nls*.json",
    "README.md",
    "LICENSE",
    "media/**",
    "scripts/cursor-patcher.js",
    "scripts/restore-cursor.js",
    "scripts/cursor-shared.js",
    "translations/**"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:cursorZhPatch.controlView"
  ],
  "contributes": {
    "configuration": {
      "title": "%ext.config.title%",
      "properties": {
        "cursorZhPatch.settingsLocale": {
          "type": "string",
          "enum": [
            "original",
            "zh-TW",
            "zh-CN",
            "ja-JP"
          ],
          "enumDescriptions": [
            "%ext.config.settingsLocale.enumDesc.original%",
            "%ext.config.settingsLocale.enumDesc.zhTW%",
            "%ext.config.settingsLocale.enumDesc.zhCN%",
            "%ext.config.settingsLocale.enumDesc.jaJP%"
          ],
          "default": "original",
          "description": "%ext.config.settingsLocale.description%"
        },
        "cursorZhPatch.systemLocale": {
          "type": "string",
          "enum": [
            "original",
            "zh-TW",
            "zh-CN",
            "ja-JP"
          ],
          "enumDescriptions": [
            "%ext.config.systemLocale.enumDesc.original%",
            "%ext.config.systemLocale.enumDesc.zhTW%",
            "%ext.config.systemLocale.enumDesc.zhCN%",
            "%ext.config.systemLocale.enumDesc.jaJP%"
          ],
          "default": "original",
          "description": "%ext.config.systemLocale.description%"
        }
      }
    },
    "commands": [
      {
        "command": "cursorZhPatch.setLocaleOriginal",
        "title": "%ext.command.setLocaleOriginal%"
      },
      {
        "command": "cursorZhPatch.setLocaleZhTW",
        "title": "%ext.command.setLocaleZhTW%"
      },
      {
        "command": "cursorZhPatch.setLocaleZhCN",
        "title": "%ext.command.setLocaleZhCN%"
      },
      {
        "command": "cursorZhPatch.setLocaleJaJP",
        "title": "%ext.command.setLocaleJaJP%"
      },
      {
        "command": "cursorZhPatch.reloadWindow",
        "title": "%ext.command.reloadWindow%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cursorZhPatch",
          "title": "%ext.views.container.title%",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "cursorZhPatch": [
        {
          "id": "cursorZhPatch.controlView",
          "name": "%ext.views.controlView.name%",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "lint": "node -e \"process.exit(0)\"",
    "package:vsix": "npx @vscode/vsce package --out \"cursor-language-toggle-$npm_package_version.vsix\""
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1"
  }
}
